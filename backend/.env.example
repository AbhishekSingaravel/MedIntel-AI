# -----------------------
# Uploads
# -----------------------
UPLOAD_DIRECTORY=uploads

# -----------------------
# JWT
# -----------------------
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest