# -----------------------
# Application
# -----------------------
APP_NAME=MedIntel AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

# -----------------------
# Server
# -----------------------
HOST=127.0.0.1
PORT=8000

# -----------------------
# Database
# -----------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medintel_ai
DB_USER=
DB_PASSWORD=

# -----------------------
# OpenAI
# -----------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# -----------------------
# Azure OpenAI
# -----------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
